{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/solicitacoes/[id]",
      "regex": "^/admin/solicitacoes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/solicitacoes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/app/propostas/[id]",
      "regex": "^/app/propostas/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/app/propostas/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/app/propostas/[id]/pagamento",
