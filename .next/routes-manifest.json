      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/app/propostas/(?<nxtPid>[^/]+?)/pagamento(?:/)?$"
    },
    {
      "page": "/app/solicitacoes/[id]",
