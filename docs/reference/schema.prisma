generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========================================
// ENUMS
// ========================================

enum UserRole {
  ADMIN
  MANAGER
  ENGINEER
  ESTIMATOR
  VIEWER

  @@map("user_role")
}

enum ProjectStatus {
  STUDY
  PRELIMINARY
  EXECUTIVE
  BIDDING
  IN_PROGRESS
  COMPLETED
  ARCHIVED

  @@map("project_status")
}

enum ProjectType {
  RESIDENTIAL
  RESIDENTIAL_MULTI
  COMMERCIAL
  HOSPITAL
  INDUSTRIAL
  EDUCATIONAL
  INFRASTRUCTURE
  RENOVATION
  OTHER

  @@map("project_type")
}

enum BudgetType {
  PARAMETRIC
  ANALYTICAL
  HYBRID
  ADDITIVE

  @@map("budget_type")
}

enum ValidationStatus {
  AI_DRAFT
  IN_REVIEW
  VALIDATED
  REJECTED

  @@map("validation_status")
}

enum PriceBase {
  SINAPI
  SICRO
  TCPO
  OWN
  MIXED

  @@map("price_base")
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW

  @@map("confidence_level")
}

enum ItemOrigin {
  AI_GENERATED
  MANUAL
  IMPORTED
  COMPOSITION

  @@map("item_origin")
}

enum DocumentType {
  FLOOR_PLAN
  MEMORIAL
  SPREADSHEET
  BIM_MODEL
  TECHNICAL
  OTHER

  @@map("document_type")
}

enum DisciplineType {
  ARCHITECTURAL
  STRUCTURAL
  ELECTRICAL
  HYDRAULIC
  HVAC
  FIRE_PROTECTION
  TELECOM

  @@map("discipline_type")
}

enum QuotationStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED

  @@map("quotation_status")
}

enum CompositionInputType {
  LABOR
  MATERIAL
  EQUIPMENT
  TRANSPORT
  OTHER

  @@map("composition_input_type")
}

enum ConstructionStandard {
  baixo
  normal
  alto

  @@map("construction_standard")
}

enum ServiceType {
  ORCAMENTO_OBRA
  ORCAMENTO_ELETRICA
  ORCAMENTO_HIDRAULICA
  ORCAMENTO_ESTRUTURAL
  PROJETO_ARQUITETONICO
  PROJETO_ELETRICO
  PROJETO_HIDRAULICO
  PROJETO_ESTRUTURAL
  LAUDO_TECNICO
  CONSULTORIA
  OUTRO

  @@map("service_type")
}

enum ServiceStatus {
  REQUESTED
  QUOTED
  APPROVED
  PAID
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED

  @@map("service_status")
}

// ========================================
// MULTI-TENANT: Empresas
// ========================================

model Company {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String
  cnpj      String?  @unique
  logo      String?
  state     String?
  priceBase PriceBase @default(SINAPI) @map("price_base")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  stripeCustomerId   String? @unique @map("stripe_customer_id")

  users           User[]
  projects        Project[]
  partners        Partner[]
  ownCompositions Composition[]
  serviceOrders   ServiceOrder[]

  @@map("companies")
}

// ========================================
// USUÁRIOS
// ========================================

model User {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  authId    String?   @unique @map("auth_id") @db.Uuid
  email     String    @unique
  name      String
  role      UserRole  @default(ESTIMATOR)
  crea      String?
  cau       String?
  companyId String    @map("company_id") @db.Uuid
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  validations Validation[]
  budgetItems BudgetItem[]

  @@map("users")
}

// ========================================
// PARCEIROS / FORNECEDORES
// ========================================

model Partner {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  cnpj        String?
  email       String?
  phone       String?
  specialties String[] @default([])
  isGlobal    Boolean  @default(false) @map("is_global")
  companyId   String?  @map("company_id") @db.Uuid
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  rating      Decimal? @db.Decimal(3, 2)
  accessToken String?  @unique @map("access_token")
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  quotes Quote[]

  @@map("partners")
}

// ========================================
// PROJETOS / OBRAS
// ========================================

model Project {
  id          String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  type        ProjectType
  status      ProjectStatus        @default(STUDY)
  description String?
  address     String?
  city        String?
  state       String?
  totalArea   Decimal?             @map("total_area") @db.Decimal(12, 2)
  standard    ConstructionStandard?
  clientName  String?              @map("client_name")
  companyId   String               @map("company_id") @db.Uuid
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  documents     Document[]
  disciplines   Discipline[]
  budgets       Budget[]
  quotations    Quotation[]
  serviceOrders ServiceOrder[]

  @@map("projects")
}

// ========================================
// DOCUMENTOS
// ========================================

model Document {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  type        DocumentType @default(OTHER)
  fileUrl     String       @map("file_url")
  fileSize    Int?         @map("file_size")
  mimeType    String?      @map("mime_type")
  projectId   String       @map("project_id") @db.Uuid
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processedAt DateTime?    @map("processed_at") @db.Timestamptz
  aiResult    Json?        @map("ai_result")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@map("documents")
}

// ========================================
// DISCIPLINAS
// ========================================

model Discipline {
  id           String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type         DisciplineType
  status       ValidationStatus @default(AI_DRAFT)
  projectId    String           @map("project_id") @db.Uuid
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiData       Json?            @map("ai_data")
  engineerData Json?            @map("engineer_data")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  validations Validation[]

  @@map("disciplines")
}

// ========================================
// ORÇAMENTOS
// ========================================

model Budget {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  version       Int              @default(1)
  type          BudgetType
  status        ValidationStatus @default(AI_DRAFT)
  priceBase     PriceBase        @default(SINAPI) @map("price_base")
  priceDate     DateTime?        @map("price_date") @db.Date
  bdiPercentage Decimal?         @map("bdi_percentage") @db.Decimal(5, 2)
  totalCost     Decimal?         @map("total_cost") @db.Decimal(14, 2)
  confidence    Decimal?         @db.Decimal(5, 2)
  projectId     String           @map("project_id") @db.Uuid
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId      String?          @map("parent_id") @db.Uuid
  parent        Budget?          @relation("BudgetVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children      Budget[]         @relation("BudgetVersions")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  items       BudgetItem[]
  validations Validation[]

  @@map("budgets")
}

// ========================================
// COMPOSIÇÕES
// ========================================

model Composition {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code          String
  description   String
  unit          String
  source        PriceBase
  unitCost      Decimal   @map("unit_cost") @db.Decimal(12, 4)
  laborCost     Decimal?  @map("labor_cost") @db.Decimal(12, 4)
  materialCost  Decimal?  @map("material_cost") @db.Decimal(12, 4)
  equipmentCost Decimal?  @map("equipment_cost") @db.Decimal(12, 4)
  state         String?
  referenceDate DateTime? @map("reference_date") @db.Date
  companyId     String?   @map("company_id") @db.Uuid
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  inputs      CompositionInput[]
  budgetItems BudgetItem[]

  @@map("compositions")
}

model CompositionInput {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type          CompositionInputType
  code          String?
  description   String
  unit          String
  coefficient   Decimal            @db.Decimal(12, 6)
  unitPrice     Decimal            @map("unit_price") @db.Decimal(12, 4)
  compositionId String             @map("composition_id") @db.Uuid
  composition   Composition        @relation(fields: [compositionId], references: [id], onDelete: Cascade)

  @@map("composition_inputs")
}

// ========================================
// ITENS DO ORÇAMENTO
// ========================================

model BudgetItem {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code          String?
  description   String
  unit          String
  quantity      Decimal         @db.Decimal(12, 4)
  unitCost      Decimal?        @map("unit_cost") @db.Decimal(12, 4)
  totalCost     Decimal?        @map("total_cost") @db.Decimal(14, 2)
  confidence    ConfidenceLevel @default(MEDIUM)
  origin        ItemOrigin      @default(AI_GENERATED)
  category      String?
  subcategory   String?
  notes         String?
  budgetId      String          @map("budget_id") @db.Uuid
  budget        Budget          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  compositionId String?         @map("composition_id") @db.Uuid
  composition   Composition?    @relation(fields: [compositionId], references: [id], onDelete: SetNull)
  createdById   String?         @map("created_by_id") @db.Uuid
  createdBy     User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  quotationItems QuotationItem[]

  @@map("budget_items")
}

// ========================================
// COTAÇÕES / MARKETPLACE
// ========================================

model Quotation {
  id        String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title     String
  status    QuotationStatus @default(OPEN)
  deadline  DateTime?       @db.Date
  projectId String          @map("project_id") @db.Uuid
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  items  QuotationItem[]
  quotes Quote[]

  @@map("quotations")
}

model QuotationItem {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  description  String
  unit         String
  quantity     Decimal     @db.Decimal(12, 4)
  budgetItemId String?     @map("budget_item_id") @db.Uuid
  budgetItem   BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  quotationId  String      @map("quotation_id") @db.Uuid
  quotation    Quotation   @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  quoteLineItems QuoteLineItem[]

  @@map("quotation_items")
}

model Quote {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId    String    @map("partner_id") @db.Uuid
  partner      Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  quotationId  String    @map("quotation_id") @db.Uuid
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  totalPrice   Decimal?  @map("total_price") @db.Decimal(14, 2)
  paymentTerms String?   @map("payment_terms")
  deadline     String?
  notes        String?
  fileUrl      String?   @map("file_url")
  isSelected   Boolean   @default(false) @map("is_selected")
  submittedAt  DateTime  @default(now()) @map("submitted_at") @db.Timestamptz

  lineItems QuoteLineItem[]

  @@map("quotes")
}

model QuoteLineItem {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  unitPrice       Decimal       @map("unit_price") @db.Decimal(12, 4)
  totalPrice      Decimal?      @map("total_price") @db.Decimal(14, 2)
  notes           String?
  quoteId         String        @map("quote_id") @db.Uuid
  quote           Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quotationItemId String        @map("quotation_item_id") @db.Uuid
  quotationItem   QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@map("quote_line_items")
}

// ========================================
// VALIDAÇÃO HUMANA
// ========================================

model Validation {
  id           String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  status       ValidationStatus
  comment      String?
  changes      Json?
  confidence   ConfidenceLevel?
  reason       String?
  suggestion   String?
  itemType     String?          @map("item_type")
  itemName     String?          @map("item_name")
  validatedBy  String           @map("validated_by") @db.Uuid
  user         User             @relation(fields: [validatedBy], references: [id], onDelete: Cascade)
  budgetId     String?          @map("budget_id") @db.Uuid
  budget       Budget?          @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  disciplineId String?          @map("discipline_id") @db.Uuid
  discipline   Discipline?      @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz

  @@map("validations")
}

// ========================================
// PEDIDOS DE SERVIÇO
// ========================================

model ServiceOrder {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title             String
  type              ServiceType
  status            ServiceStatus @default(REQUESTED)
  description       String?
  price             Decimal?      @db.Decimal(12, 2)
  stripePaymentId   String?       @unique @map("stripe_payment_id")
  companyId         String        @map("company_id") @db.Uuid
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId         String?       @map("project_id") @db.Uuid
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliveryNotes     String?       @map("delivery_notes")
  quotedAt          DateTime?     @map("quoted_at") @db.Timestamptz
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz
  deliveredAt       DateTime?     @map("delivered_at") @db.Timestamptz
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("service_orders")
}

// ========================================
// API KEYS
// ========================================

model ApiKey {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  key         String   @unique
  companyId   String   @map("company_id") @db.Uuid
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("api_keys")
}
